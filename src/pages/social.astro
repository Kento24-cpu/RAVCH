---
import BaseLayout from "../layouts/BaseLayout.astro"
import { Icon } from "astro-icon/components";
const pageTitle = "Redes Sociales"
---

<BaseLayout pageTitle={ pageTitle }>
  <div class="max-w-3xl mx-auto">
    <h1 class="font-bold text-3xl text-primary dark:text-primary-dark text-center mb-8">{ pageTitle }</h1>

    <div class="rounded-2xl p-8 bg-surface dark:bg-surface-dark shadow-md border border-border dark:border-border-dark transition-colors duration-300 text-center">
      <span class="text-6xl block mb-6">🌐</span>
      <p class="text-text dark:text-text-dark text-lg mb-6">
        Síguenos en nuestras redes sociales para estar al tanto de nuestras transmisiones en vivo,
        eventos y mensajes.
      </p>
      <div class="flex justify-center gap-6">
        <a
          href="https://www.facebook.com/Riosdeaguavivachinandega"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 px-6 py-3 rounded-xl bg-[#1877F2] text-white font-semibold text-lg hover:bg-[#166fe5] transition-all hover:scale-105 shadow-md"
        >
          <Icon name="mdi:facebook" class="text-2xl" />
          Facebook
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
