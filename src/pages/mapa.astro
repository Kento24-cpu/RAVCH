---
import BaseLayout from "../layouts/BaseLayout.astro"
const pageTitle = "RAVCH | Ubicacion"
---

<BaseLayout pageTitle={ pageTitle }>
  <div class="max-w-4xl mx-auto">
    <h1 class="font-bold text-3xl text-primary dark:text-primary-dark text-center mb-4">
      Ubicación
    </h1>
    <p class="text-center text-text dark:text-text-dark mb-8">
      Visítanos en nuestro local de culto. Estamos ubicados en Chinandega, Nicaragua.
    </p>
    <div class="rounded-2xl overflow-hidden shadow-md border border-border dark:border-border-dark">
      <iframe
        src="https://www.openstreetmap.org/export/embed.html?bbox=-87.1387%2C12.6106%2C-87.1287%2C12.6206&amp;layer=mapnik&amp;marker=12.6156%2C-87.1337"
        width="100%"
        height="450"
        style="border:none"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</BaseLayout>
