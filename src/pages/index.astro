---
import { Image } from "astro:assets"
import banner_morning from "../assets/banner.webp"
import banner_night from "../assets/banner2.webp"
import BaseLayout from "../layouts/BaseLayout.astro"
import VerseDay from "../components/VerseDay.astro"

const pageTitle = "Rios de Agua Viva Chinandega"
---

<BaseLayout pageTitle={ pageTitle }>
  <section class="mb-12">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="font-bold text-3xl text-primary dark:text-primary-dark">
        Bienvenidos a la página de RAVCH 2026!
      </h1>
      <p class="text-text dark:text-text-dark py-4 px-4 leading-relaxed">
        <b class="text-xl">Dios les bendiga!</b>
        <br><br>
        El Ministerio Evangelístico Ríos de Agua Viva Chinandega
        les da la bienvenida a su página web oficial donde conocerá sobre la <b>Misión</b>,
        <b>Visión</b> y <b>objetivo principal</b> de nuestro ministerio.
        <br><br>
        También conocerá sobre nuestros eventos y transmisiones en vivo en nuestra página de Facebook
        <a
          href="https://www.facebook.com/Riosdeaguavivachinandega"
          class="cursor-pointer transition-all hover:text-accent dark:hover:text-accent-dark hover:border-b-2 border-accent dark:border-accent-dark font-bold"
          target="_blank"
          rel="noopener noreferrer"
        >Ríos De Agua Viva "Chinandega"</a>
      </p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-primary dark:text-primary-dark text-2xl font-bold text-center mb-6">Horarios de Culto</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-4xl mx-auto">
      <div class="rounded-2xl overflow-hidden shadow-md border border-border dark:border-border-dark transition-all hover:shadow-lg">
        <Image
          src={ banner_morning }
          alt="Horario por la mañana"
          class="w-full h-auto"
        />
      </div>
      <div class="rounded-2xl overflow-hidden shadow-md border border-border dark:border-border-dark transition-all hover:shadow-lg">
        <Image
          src={ banner_night }
          alt="Horario por la noche"
          class="w-full h-auto"
        />
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-primary dark:text-primary-dark text-2xl font-bold text-center mb-6">Última Transmisión</h2>
    <div class="max-w-3xl mx-auto rounded-2xl overflow-hidden shadow-md border border-border dark:border-border-dark bg-surface dark:bg-surface-dark p-2">
      <iframe
        src="https://www.facebook.com/plugins/video.php?href=https%3A%2F%2Fwww.facebook.com%2FRiosdeaguavivachinandega%2Fvideos%2F1545018300599977%2F"
        style="border:none;overflow:hidden"
        allowfullscreen="true"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
        class="w-full max-w-full h-56 sm:h-106 rounded-2xl"
      ></iframe>
    </div>
  </section>

  <section>
    <VerseDay />
  </section>
</BaseLayout>
