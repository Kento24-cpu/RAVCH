---
import { Icon } from "astro-icon/components";
---

<button id="sidebar-open" class="fixed text-3xl bg-secondary dark:bg-secondary-dark text-white rounded p-2 top-4 left-4 cursor-pointer transition-transform hover:scale-105 z-50 lg:hidden">
  <Icon name="heroicons:bars-3-bottom-left" />
</button>

<div id="sidebar" class="sidebar fixed min-h-dvh w-64 p-4 -translate-x-full text-center overflow-y-auto bg-secondary dark:bg-secondary-dark transition-all duration-300 ease-in-out z-50">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2">
      <img src="/logo-wb.webp" alt="Logo" class="size-8">
      <h1 class="font-bold text-text-dark">RAVCH</h1>
    </div>
    <button id="sidebar-close" class="text-2xl text-text-dark cursor-pointer transition-transform hover:scale-110">
      <Icon name="mdi:close" />
    </button>
  </div>

  <hr class="border-text-dark/20 mb-4">

  <nav class="flex flex-col gap-3">
    <a href="/"
      class="sidebar-link w-full py-2 px-3 rounded-xl text-left font-semibold flex items-center gap-3 text-text-dark transition-colors hover:bg-accent hover:text-primary">
      <span class="text-xl"><Icon name="heroicons:home-solid" /></span>
      Pagina Principal
    </a>
    <a href="/about"
      class="sidebar-link w-full py-2 px-3 rounded-xl text-left font-semibold flex items-center gap-3 text-text-dark transition-colors hover:bg-accent hover:text-primary">
      <span class="text-xl"><Icon name="heroicons:user-group-16-solid" /></span>
      Acerca de
    </a>
    <a href="/social"
      class="sidebar-link w-full py-2 px-3 rounded-xl text-left font-semibold flex items-center gap-3 text-text-dark transition-colors hover:bg-accent hover:text-primary">
      <span class="text-xl"><Icon name="heroicons:camera-20-solid" /></span>
      Redes Sociales
    </a>
  </nav>

  <hr class="border-text-dark/20 my-4">

  <button id="sidebar-dark-toggle" class="flex items-center justify-center gap-2 w-full py-2 px-3 rounded-xl text-text-dark font-semibold transition-colors hover:bg-accent hover:text-primary cursor-pointer">
    <span id="sidebar-theme-icon">🌙</span>
    <span>Modo Oscuro</span>
  </button>
</div>

